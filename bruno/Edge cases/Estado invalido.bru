meta {
  name: Estado invalido (400)
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/tickets/{{ticketId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
  Content-Type: application/json
}

body:json {
  {
    "state": "TERMINADO"
  }
}

assert {
  res.status: eq 400
}

docs {
  state valido solo: NEW, ASSIGNED, IN_PROGRESS, RESOLVED, CLOSED.
}
