meta {
  name: Crear ticket sin title (400)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/tickets
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
  Content-Type: application/json
}

body:json {
  {
    "description": "Falta el titulo",
    "areaId": "{{areaId}}"
  }
}

assert {
  res.status: eq 400
}
