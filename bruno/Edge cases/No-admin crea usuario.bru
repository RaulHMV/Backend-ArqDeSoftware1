meta {
  name: No-admin crea usuario (403)
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{requesterToken}}
  Content-Type: application/json
}

body:json {
  {
    "userId": "x",
    "email": "x@x.com",
    "role": "ADMIN"
  }
}

assert {
  res.status: eq 403
}

docs {
  Solo ADMIN puede crear/editar usuarios. Evita escalada de privilegios.
}
