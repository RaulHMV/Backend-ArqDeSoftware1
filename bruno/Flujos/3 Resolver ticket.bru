meta {
  name: 3 Resolver ticket (a RESOLVED)
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/tickets/{{ticketId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{idToken}}
  Content-Type: application/json
}

body:json {
  {
    "state": "RESOLVED",
    "resolutionNotes": "Se reinicio el spooler y volvio a imprimir",
    "reason": "Solucionado"
  }
}

assert {
  res.status: eq 200
}

docs {
  Al pasar a RESOLVED el backend agrega resolvedAt automaticamente.
}
